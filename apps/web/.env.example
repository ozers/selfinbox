# Build mode for the SPA.
#   app       — strict private deploy. `/` → `/login`, no public landing (default).
#   public    — public landing at `/` + full app. The landing has no Sign In
#               link; the owner bookmarks `/login` to access the dashboard.
#   marketing — landing only. No login, no API. Other paths redirect to GitHub.
# Only consumed at build time (Vite). The Dockerfile accepts it as a build arg.
VITE_MODE=app

# Where the API lives. Empty = same origin (default for the single-process
# Docker build that serves SPA + API together). Set this only if you split
# the SPA and API across different hosts.
VITE_API_URL=

# Branding baked into the SPA bundle at build time.
VITE_BRAND_NAME=Selfinbox
VITE_SUPPORT_EMAIL=
