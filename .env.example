# ─── Required ──────────────────────────────────────────────────────────────────

# Postgres connection string. Any provider works (Neon, Supabase, Railway, RDS, local).
DATABASE_URL=postgres://user:pass@localhost:5432/selfinbox

# Random 32+ char secret for signing JWTs. Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# Public URL where this app is served (no trailing slash).
# Used for OAuth redirects and email links. In dev: http://localhost:3001
APP_URL=http://localhost:3001

# Verified SES sender used for system emails (verification, password reset, forwarding).
# Must be verified in SES (the address itself, or the whole domain).
FROM_EMAIL=noreply@yourdomain.com

# ─── AWS ───────────────────────────────────────────────────────────────────────
# Used for: sending email (SES), receiving inbound email (SES → S3 → SNS → webhook).
# scripts/setup-aws.sh provisions everything below except the keys.

AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket where SES drops inbound raw emails. Created by setup-aws.sh.
S3_INBOUND_BUCKET=selfinbox-inbound

# ─── SMTP credentials shown to users for their domain ─────────────────────────
# Defaults to AWS SES SMTP endpoint for AWS_REGION. Override only if you front
# SES with your own SMTP relay.
# SMTP_HOST=email-smtp.eu-west-1.amazonaws.com
# SMTP_PORT_EXTERNAL=587

# ─── Optional: open registration ──────────────────────────────────────────────
# Set to "true" to allow anyone to register. Otherwise only seeded users can sign in.
REGISTRATION_ENABLED=false

# ─── Optional: Cloudflare auto DNS ────────────────────────────────────────────
# Two ways to enable Cloudflare auto-setup. Either is fine; OAuth is friendlier
# for multi-tenant deploys, the API token is simpler for solo/self-host.

# Option A — single API token (creates DNS records on the operator's account)
# CLOUDFLARE_API_TOKEN=

# Option B — OAuth (each user connects their own Cloudflare account)
# CLOUDFLARE_CLIENT_ID=
# CLOUDFLARE_CLIENT_SECRET=

# ─── Optional: branding (frontend) ────────────────────────────────────────────
# These are read at build time (Vite) and bake into the bundle.
# VITE_BRAND_NAME=Selfinbox
# VITE_SUPPORT_EMAIL=hello@yourdomain.com
# VITE_API_URL=                # leave empty when serving SPA + API from the same origin

# ─── Runtime ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
